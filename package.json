{
  "name": "truck-workshop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Workspace para la plataforma Truck Workshop, con frontend instalable y backend API.",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:all": "npm --prefix frontend run dev:all",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npm --prefix frontend run typecheck",
    "check": "npm --prefix frontend run check",
    "preview": "npm --prefix frontend run preview",
    "desktop:preview": "npm --prefix frontend run desktop:preview",
    "desktop:pack": "npm --prefix frontend run desktop:pack",
    "desktop:dist": "npm --prefix frontend run desktop:dist",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "backend:migrate": "npm --prefix backend run migrate",
    "backend:seed": "npm --prefix backend run seed:from-mocks",
    "backend:db:reset": "npm --prefix backend run db:reset",
    "backend:db:audit": "npm --prefix backend run db:audit",
    "db:up": "docker compose up -d sqlserver",
    "db:down": "docker compose down"
  }
}
