NODE_ENV=development
PORT=4000
API_PREFIX=/api
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5181,http://localhost:5181,http://127.0.0.1:5183,http://localhost:5183
DATA_DRIVER=sqlserver

SQL_SERVER=.\CATA
SQL_PORT=
SQL_DATABASE=TruckWorkshop
SQL_AUTH_TYPE=trusted
SQL_USER=
SQL_PASSWORD=
SQL_ENCRYPT=false
SQL_TRUST_SERVER_CERTIFICATE=true

# Google Maps Platform (habilitar Places API, Routes API y Maps Static API)
# Si GOOGLE_MAPS_API_KEY queda vacio, el backend usa OpenStreetMap/Nominatim + OSRM para busqueda y distancias.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_COUNTRY=cl
GOOGLE_MAPS_LANGUAGE=es-419
GOOGLE_MAPS_REGION_CODE=CL
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=https://router.project-osrm.org
MAPS_USER_AGENT=truck-workshop-api/1.0

# Precio de combustible: scraping de un sitio publico (SIN token).
# Por defecto obtiene el promedio nacional de diesel desde preciocombustible.cl
# una vez al dia a las 06:00 hora de Chile. Si el scraping falla, la app usa
# FUEL_FALLBACK_DIESEL_PRICE_PER_LITER marcado como "Referencial".
FUEL_SCRAPER_ENABLED=true
FUEL_SCRAPER_URL=https://preciocombustible.cl/
FUEL_SCRAPER_SOURCE_LABEL=preciocombustible.cl
FUEL_SCRAPER_REQUEST_TIMEOUT_MS=12000
# Hora local (0-23) y zona horaria del disparo diario.
FUEL_SCRAPER_DAILY_HOUR=6
FUEL_SCRAPER_TIMEZONE=America/Santiago
FUEL_DEFAULT_FUEL_TYPE=DIESEL
FUEL_DEFAULT_REGION_CODE=13
FUEL_FALLBACK_DIESEL_PRICE_PER_LITER=1050

# Para autenticacion Windows/NTLM:
# SQL_AUTH_TYPE=ntlm
# SQL_DOMAIN=MI_DOMINIO
# SQL_USER=mi.usuario
# SQL_PASSWORD=mi-password-windows

JWT_SECRET=replace-with-a-long-secret
JWT_EXPIRES_IN=8h
AUTH_REQUIRED=false
AUTH_ENFORCE_PERMISSIONS=false
AUTH_ALLOW_DEVELOPMENT_LOGIN=true
DEV_LOGIN_EMAIL=admin@truckworkshop.cl
DEV_LOGIN_PASSWORD_HASH=123

# GPS / Telematica DS-TMS (posicion en vivo de la flota). Tokens SOLO en backend.
# Pide tus tokens al proveedor (ds-tms.com). No los subas al repo.
DSTMS_ENABLED=true
DSTMS_BASE_URL=https://www.ds-tms.com
DSTMS_CLIENT=mimbral
DSTMS_LAST_POSITION_TOKEN=
DSTMS_HISTORY_TOKEN=
DSTMS_REQUEST_TIMEOUT_MS=15000
